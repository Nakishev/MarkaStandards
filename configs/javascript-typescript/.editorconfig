# ──────────────────────────────────────────────────────────────
# Marka .editorconfig — JavaScript / TypeScript
# Covers: Next.js, Nest.js, React, Vite, plain Node apps
# ──────────────────────────────────────────────────────────────
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript and JavaScript source files
[*.{js,cjs,mjs,ts,cts,mts,tsx,jsx}]
indent_size = 2
quote_type = single

# JSON (package.json, tsconfig.json, etc.)
[*.json]
indent_size = 2
insert_final_newline = true

# JSON with comments (tsconfig, VS Code settings)
[*.jsonc]
indent_size = 2

# YAML (CI pipelines, Docker Compose)
[*.{yml,yaml}]
indent_size = 2

# CSS / SCSS / Less
[*.{css,scss,less}]
indent_size = 2

# HTML / JSX templates
[*.html]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = 120

# Makefiles must use tabs
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
end_of_line = lf
indent_size = 2
