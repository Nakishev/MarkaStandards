# ──────────────────────────────────────────────────────────────
# Marka .gitignore — JavaScript / TypeScript
# Covers: Next.js, Nest.js, React, Vite, plain Node / NestJS
# ──────────────────────────────────────────────────────────────

########################################
# OS junk
########################################
.DS_Store
Thumbbs.db
Desktop.ini

########################################
# Editor / IDE
########################################
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
# Uncomment to share workspace settings:
# !.vscode/settings.json
*.code-workspace
.history/

.idea/
*.iml

########################################
# Dependencies
########################################
node_modules/
**/node_modules/
jspm_packages/

########################################
# Package manager caches / lock helpers
########################################
.npm/
.pnpm-store/
**/.pnpm-store/
**/.pnpm-cache/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
# Keep .yarn/releases and .yarn/plugins if using Yarn Berry:
# !.yarn/releases/
# !.yarn/plugins/

########################################
# Build output
########################################
dist/
build/
out/

# Framework-specific outputs
.next/
.nuxt/
.svelte-kit/
.remix/

# Vite / Vitest
.vite/
.vitest/
.vitest-cache/

# Storybook
storybook-static/

########################################
# TypeScript
########################################
*.tsbuildinfo
*.d.ts.map

########################################
# Test artifacts
########################################
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/
cypress/videos/
cypress/screenshots/
blob-report/

########################################
# Logs
########################################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

########################################
# Runtime / pid
########################################
pids/
*.pid
*.seed
*.pid.lock

########################################
# Local environment / secrets
########################################
.env
.env.*
!.env.example
!.env.template

########################################
# Linter / formatter caches
########################################
.eslintcache
.stylelintcache
.biome/

########################################
# Monorepo / task runners
########################################
.turbo/
.nx/

########################################
# Terraform (if present in monorepo)
########################################
.terraform/
*.tfstate
*.tfstate.*
crash.log

########################################
# AI editor local folders
########################################
.cursor/
.windsurf/
.roo/
.kilocode/
.augment/
copilot-instructions*
