# ──────────────────────────────────────────────────────────────
# Marka .gitignore — Terraform / OpenTofu / Pulumi / Bicep
# ──────────────────────────────────────────────────────────────

########################################
# Terraform / OpenTofu
########################################

# Local .terraform directories (provider plugins, modules)
**/.terraform/*
.terraform/
.terraform.lock.hcl    # Commit this in application repos; ignore in modules

# State files — never commit; use remote state (Azure Blob, Terraform Cloud)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Lock info (transient, generated during apply)
.terraform.tfstate.lock.info

# Override files — local developer overrides, not for shared use
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
# Exception: keep example / template var files
!*.tfvars.example
!*.tfvars.template

# Plan files — generated artifacts, not source
*.tfplan
*.plan

# Backend config files (may contain sensitive endpoints/tokens)
backend.config
backend.*.config
!backend.config.example

# CLI config (local developer setting)
.terraformrc
terraform.rc

########################################
# Pulumi
########################################

# Local stack state and secrets passphrase
.pulumi/
Pulumi.*.yaml    # Stack files may contain secrets; use Pulumi secrets backend
# Exception: keep the base Pulumi.yaml project file
!Pulumi.yaml

# Node/Python virtualenv used by Pulumi programs
node_modules/
__pycache__/
.venv/
venv/

########################################
# Azure Bicep / ARM
########################################

# ARM template parameter files with sensitive values
*.parameters.json
# Keep example parameter files
!*.parameters.example.json
!*.parameters.template.json

# Bicep build output (ARM JSON generated by bicep build)
*.json
# Exception: keep shared module / schema JSON
!modules/**/*.json
!.bicep/
!bicepconfig.json

########################################
# Ansible (if used alongside IaC)
########################################
*.retry
.vault_pass
vault_password_file

########################################
# General
########################################

# OS junk
.DS_Store
Thumbbs.db

# Editor metadata
.vscode/
.idea/
*.code-workspace

# Environment / secrets
.env
.env.*
!.env.example
